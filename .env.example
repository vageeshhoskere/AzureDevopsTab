# Opencode server URL
VITE_OPENCODE_API_URL=http://localhost:4096

# Optional: pin a specific AI provider + model for every prompt.
# Both must be set together; if either is blank the backend default is used.
# Example: VITE_OPENCODE_PROVIDER_ID=anthropic
#          VITE_OPENCODE_MODEL_ID=claude-sonnet-4-5
VITE_OPENCODE_PROVIDER_ID=
VITE_OPENCODE_MODEL_ID=

# Optional: route every prompt to a named Opencode agent.
# Example: VITE_OPENCODE_AGENT=azure-devops
VITE_OPENCODE_AGENT=
